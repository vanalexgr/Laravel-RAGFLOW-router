modules = ["php-8.4", "nodejs-20", "python-3.11"]
[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Laravel Server"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "RAGFlow Bridge"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "KeepAlive"

[[workflows.workflow]]
name = "Laravel Server"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export API_SECRET_KEY=\"$API_SECRET_KEY\" && php artisan serve --host=0.0.0.0 --port=5000"
waitForPort = 5000

[[workflows.workflow]]
name = "RAGFlow Bridge"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd ragflow_service && python -m uvicorn app:app --host 0.0.0.0 --port 8000 --timeout-keep-alive 120 --timeout-graceful-shutdown 30"
waitForPort = 8000

[[workflows.workflow]]
name = "KeepAlive"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export API_SECRET_KEY=\"$API_SECRET_KEY\" && bash scripts/keepalive.sh"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8000
externalPort = 8000

[userenv]

[userenv.shared]
APP_URL = "https://laravel-ragflow-router--alexiouv.replit.app"
RAGFLOW_API_KEY = "RAGFLOW_API_KEY_REDACTED"
RAGFLOW_BASE_URL = "https://ragflow.clinicalguidelines.io"
VIZRA_ADK_DRIVER = "azure"
AZURE_OPENAI_API_KEY = "AZURE_OPENAI_API_KEY_REDACTED"
AZURE_OPENAI_BASE_URL = "https://alexiouv-5401-resource.cognitiveservices.azure.com/openai/deployments/gpt-5-chat"
AZURE_OPENAI_VERSION = "2024-12-01-preview"
AZURE_OPENAI_ENDPOINT = "https://alexiouv-5401-resource.cognitiveservices.azure.com"
AZURE_OPENAI_DEPLOYMENT = "gpt-5-chat"
VIZRA_ADK_ENABLED = "true"
VIZRA_ADK_DEFAULT_PROVIDER = "azure"
VIZRA_ADK_DEFAULT_MODEL = "gpt-5-chat"
RAGFLOW_ENDPOINT = "https://ragflow.clinicalguidelines.io/api/v1"
APP_ENV = "production"
APP_DEBUG = "false"
APP_KEY = "APP_KEY_REDACTED"
RAGFLOW_RERANK_ID = "Cohere-rerank-v4.0-pro___OpenAI-API@OpenAI-API-Compatible"

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "cd ragflow_service && python -m uvicorn app:app --host 0.0.0.0 --port 8000 & sleep 3 && php artisan serve --host=0.0.0.0 --port=5000"]
