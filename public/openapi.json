{
    "openapi": "3.1.0",
    "info": {
        "title": "Vascular Expert Tools",
        "description": "API for accessing ESVS Vascular Guidelines",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "https://your-domain.com",
            "description": "API Base URL"
        }
    ],
    "paths": {
        "/api/v1/vascular-consult": {
            "post": {
                "operationId": "consult_guidelines",
                "summary": "Consult Vascular Guidelines",
                "description": "Retrieves evidence-based recommendations from ESVS guidelines.",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "question": {
                                        "type": "string",
                                        "description": "The clinical question to answer"
                                    },
                                    "history": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "description": "Optional conversation history"
                                    },
                                    "guidelines": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        },
                                        "description": "Optional list of guideline keys to scope retrieval (max 3)"
                                    }
                                },
                                "required": [
                                    "question"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful retrieval",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "result": {
                                            "type": "string",
                                            "description": "Formatted retrieval output for LLMs"
                                        },
                                        "narrative_chunks": {
                                            "type": "array",
                                            "description": "Narrative chunks for synthesis",
                                            "items": {
                                                "type": "object"
                                            }
                                        },
                                        "citation_chunks": {
                                            "type": "array",
                                            "description": "Citation chunks for verbatim recommendations",
                                            "items": {
                                                "type": "object"
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "API Key"
            }
        }
    },
    "security": [
        {
            "bearerAuth": []
        }
    ]
}
